	order_index: 1
	quest_links: [ ]
	quests: [
		{
			description: [
				"&7При создании или получении инструментов, бронь или оружий, ты заметишь что они имеют качество/редкость."
				""
				"&7Редкости разнятся от:"
				"&8- &fОбычный"
				"&8- &2Необычный"
				"&8- &3Редкий"
				"&8- &dЭпический"
				"&8- &6Легендарный"
				"&8- &cМифический"
				""
				"{@pagebreak}"
				""
				"&6Перековка&7 это важная часть твоей прогрессии, ведь она позволяет изменять редкость предмета."
				""
				"&7Чтобы это сделать, найди вкладку &eПерековка&7 в &eНаковальне&7. Тебе понадобиться:"
				""
				"&8- &eБазовый Материал &8(Левый Слот)"
				"&8- &eПредмет для Перековки &8(Средний Слот)"
				"&8- &eПерековочный Материал &8(Правый Слот)"
				""
				""
				"{@pagebreak}"
				""
				"&e&lБазовый Материал &r&8(Левый Слот)"
				""
				"&7Базовый Материал относится напрямую к перековываемому предмету. Например, &eСвятой Посох&7 потребует &eЗолотой Слиток&7 как базовый материал. Ты можешь увидеть требуемые материалы, наведя курсор на кнопку перековки после того как ты положил предмет в средний слот."
				""
				""
				"{@pagebreak}"
				""
				"&e&lПредмет для Перековки &r&8(Средний Слот)"
				""
				"&7Предмет которому ты хочешь поменять редкость. Не все предметы перековываемы, только предметы, оружия и брони."
				""
				""
				"{@pagebreak}"
				""
				"&e&lПерековочный Материал"
				""
				"&7Этот материал определит редкость предмета после перековки, есть 3 уровня материалов что ты можешь увидеть в следующих квестах."
				""
				""
				"{@pagebreak}"
				""
				"&a&lУвеличение твоих шансов"
				""
				"&7Это не только о гринде! Ты можешь &eувеличить шансы на большую редкость&7 своей &aУдачей&7! Предметы которые пассивно дают удачу, зелья удачи, аксессуары, вино, что угодно!"
			]
			id: "3C95FD1F14D109CF"
			shape: "hexagon"
			subtitle: "&8[Нажмите, чтобы прочитать инструкции]"
			tasks: [{
				id: "71FAC91280FBBF9C"
				item: "minecraft:anvil"
				title: "Создай Наковальню"
				type: "item"
			}]
			title: "&6&lПервые Шаги:&f Наковальня"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["3C95FD1F14D109CF"]
			description: [
				""
				"&7&nКусок Известняка&r&7 это первый уровень перековочных материалов."
				""
				"&7Он находится в &aВерхнем Мире&7, получается &eсозданием&7 из 4-х &fБлоков известняка&r&8 (для 4 штук)&7, или 4-х &fБлоков диорита&r &8(для 4 штук)"
				""
				"&7Может перековывать до следующих редкостей:"
				"&8- &fОбычная"
				"&8- &2Необычная"
				"&8- &3Редкая"
				"&8- &dЭпическая"
			]
			id: "4D3F0D8217067D24"
			shape: "diamond"
			subtitle: "&8[Нажми, чтобы прочитать инструкции]"
			tasks: [{
				id: "4593A7256861742B"
				item: "tiered:limestone_chunk"
				type: "item"
			}]
			title: "&6&lУровень I: &fИзвестняк"
			x: 0.0d
			y: 2.5d
		}
		{
			dependencies: ["4D3F0D8217067D24"]
			description: [
				""
				"&7&nКусок Пирита&r&7 это второй уровень перековочного материала."
				""
				"&7Он находится в &cАду&7, Получается &eСозданием&7 используя 4 &6Пиритовой Пыли*&r&8 (для 1 штуки)&7, или же &eПереплавкой&7 &6Древних Обломков&r&7 &8(для 4 штук)"
				""
				"&8* Пиритовая Пыль получается вскапыванием Пиритовой Руды в Аду"
				""
				"&7Перековывает до следующих редкостей:"
				"&8- &2Необычный"
				"&8- &3Редкий"
				"&8- &dЭпический"
				"&8- &6Легендарный"
			]
