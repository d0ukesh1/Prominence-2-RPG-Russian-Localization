	quests: [
		{
			description: [
				"&dТребует завершения &nГлавы I&r&d Вторжения Пустоты."
				""
				"&7Литое ядро - это мощный артефакт созданный в глубине Пепельного Вулкана; &cВааз&7."
				"&7С ним, ты можешь создать мощнейшее и уникальное вооружение, которое будет привязано к твоей душе, что делает его возможным к использованию только для того, кто его выковал, а также имеет &eособые способности&7."
				""
				"&bЗаключенные остатки&7 используются для починки и перековки этих оружий. Тебе также стоит создать &dУкрепляющий Катализатор&7 чтобы сделать их неразрушимыми."
			]
			icon: "prominent:molten_core"
			id: "6AD67E7C8CD78371"
			rewards: [
				{
					id: "5562501929CD8443"
					type: "xp_levels"
