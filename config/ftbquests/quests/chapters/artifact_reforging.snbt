					type: "item"
				}
			]
			shape: "diamond"
			size: 1.5d
			subtitle: "&8[Нажми, чтобы прочитать лор и инструкции]"
			tasks: [
				{
					id: "035441107821B3C1"
					item: "prominent:molten_core"
					type: "item"
				}
				{
					id: "56A625D024CDB2DE"
					item: "things:hardening_catalyst"
					title: "Создай Укрепляющий Катализатор"
					type: "item"
				}
			]
			title: "&cКузня С'келлака"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["6AD67E7C8CD78371"]
			description: [
				"&eКуется с использованием Эссенции Гнева и Пробужденного Клинка Лича, вместе с Литым ядром."
				""
				""
				"&7Этот предмет является данью уважения Frostmourn-у из World of Warcraft."
			]
			id: "341DB238063321BF"
			shape: "hexagon"
			subtitle: "Проклятый меч, который носит силу вечной зимы. Ледяная Скорбь - это рунический артефакт, созданный с помощью ледяной магии. Легенда гласит - любой кто возьмет его, станет правителем Рыцарей Смерти, Королем Личем."
			tasks: [{
				id: "7F239D03EBB09534"
				item: {
					Count: 1b
					id: "prominent:frostmourne"
					tag: {
						Damage: 0
					}
				}
				type: "item"
			}]
			x: -2.0d
			y: -2.0d
		}
		{
			dependencies: ["6AD67E7C8CD78371"]
			description: [
				"&eКуется с помощью двух Расплавленных Топоров вместе с Литым Ядром."
				""
				""
				"&7Этот предмет является данью уважения Fyr'alath-у из World of Warcraft."
			]
			id: "6D1B83D633AB7558"
			shape: "hexagon"
			subtitle: "Агонизирующее оружие огненной души, которое даёт отличную защиту его владельцу. Ориентировано на защиту, но имеет отличный урон от огня."
			tasks: [{
				id: "52D24DAEDFD19F9A"
				item: {
					Count: 1b
					id: "prominent:fyralath"
					tag: {
						Damage: 0
					}
				}
				type: "item"
			}]
			x: -3.0d
			y: 0.0d
		}
		{
			dependencies: ["6AD67E7C8CD78371"]
			description: ["&eКуется с использованием Демонической Эссенции и Душераздирателя вместе с Литым ядром."]
			id: "5D03084D09D2A997"
			shape: "hexagon"
			subtitle: "&7A'зар это демон, пойманный в ловушку в форме косы С'келлаком, что делает это оружие огненной души довольно недружелюбным, будь осторожен, когда используешь его, ведь оно попытается предать тебя."
			tasks: [{
				id: "43F5AAA9405EE27D"
				item: {
					Count: 1b
