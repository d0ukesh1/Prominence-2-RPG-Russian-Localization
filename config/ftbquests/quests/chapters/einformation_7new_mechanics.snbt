			}]
			title: "&eБроня \\& Твёрдость брони"
			x: -2.5d
			y: -6.5d
		}
		{
			dependencies: ["3F794C7D175F14C0"]
			description: [
				"- &eЗдоровье"
				"&7Увеличивает максимальное количество урона, которое ты можешь получить, прежде чем умереть."
				""
				"- &eВыносливость"
				"&7Уменьшает количество энергии (голода), которое ты теряешь пассивно."
			]
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
