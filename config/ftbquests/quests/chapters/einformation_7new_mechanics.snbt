	quest_links: [ ]
	quests: [
		{
			dependencies: ["6930C77988A640AF"]
			description: [
				"Все щиты получили новые механики из мода &eShield Overhaul&r."
				""
				"&e&lРывок &r&7Атакуй во время блока чтобы выполнить рывок щитом. &7Это ошеломит цель на 1 секунду, если это не босс."
			]
			icon: {
				Count: 1b
				id: "minecraft:shield"
				tag: {
					Damage: 0
				}
			}
			id: "51595E88AF1F475E"
			rewards: [{
				id: "73FEF9863E4C5F38"
				type: "xp"
				xp: 100
			}]
			shape: "hexagon"
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "7AAEF7553C3616AE"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eНовая защитная механика"
			x: 1.5d
			y: -2.5d
		}
		{
			dependencies: ["6930C77988A640AF"]
			description: [
				"&7Боевые механики были изменены модом &eBetter Combat&7."
				""
				"- &6&lОружие &r&7Каждое оружие имеет свою анимацию атаки и время."
				""
				"- &6&lКомбо &r&7Последовательные атаки выполнят комбо."
				""
				"- &6&lУдерживайте для атаки &r&7Вы можете удерживать кнопку атаки, чтобы продолжать атаку."
			]
			icon: {
				Count: 1b
				id: "minecraft:netherite_sword"
				tag: {
					Damage: 0
				}
			}
			id: "6B8B4323E13AB3E9"
			rewards: [{
				id: "475CDA6694C41230"
				type: "xp"
				xp: 100
			}]
			shape: "hexagon"
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "3589A9BB969BA94E"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eНовая боевая механика"
			x: -1.5d
			y: -2.5d
		}
		{
			description: [
				"&7Этот учебный раздел объясняет, как работает бой, рассматривает изменённые механики для того, чтобы спланировать развитие своего персонажа."
				""
				"&eХотя этот раздел для начальной игры, он охватывает и сборки для конца игры. Новые квесты появятся по мере вашего прогресса."
				""
				"&7Большая часть этого раздела — это чтение, &cпоэтому пожалуйста, убедись, что все прочитал&7, если хочешь действительно понять все, так как это важная информация."
			]
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "ftblibrary:icons/info_gray"
				}
			}
			id: "6930C77988A640AF"
			shape: "hexagon"
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "4B87D5A81113B3B8"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eКак работает Бой \\& Усиление персонажа?"
			x: 0.0d
			y: -3.0d
		}
		{
			dependencies: [
				"51595E88AF1F475E"
				"6B8B4323E13AB3E9"
			]
			description: [
				"&7Следующие руководства укажут тебе, на что обращать внимание в зависимости от типа сборки. Это не полностью разработанные сборки, а лишь руководства для того, чтобы выбрать подходящее снаряжение, соответствующее твоему стилю игры."
				""
				"&eПоказанная сложность относится как к трудности игры, так и к трудности создания сборки &7(хотя сложность игрового процесса имеет более высокий приоритет)&7."
				""
				"&6Как работают уровни?"
				""
				"&7Уровень I: &eНачальное снаряжение &8(Мир)"
				"&eУровень II: &eРанняя игра &8(После Нижнего мира)"
				"&6Уровень III: &eСредняя игра &8(После Края)"
				"&cУровень IV: &eПоздняя/Конечная игра &8(После Артефактов)"
				"&dУровень V: &e&kДревний&r &8(Неизвестно)"
				""
				"&eЭта часть руководства может быть сложной! Чтобы узнать больше о получении Книг Умений, пожалуйста, прочитай квесты по Заклинаниям."
				""
				"&6Для полных руководств по конкретным сборкам, смотри официальный вики-сайт!"
			]
			hide: true
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "tiered:textures/gui/anvil_tab_icon.png"
				}
			}
			id: "61C05AE305488DF5"
			shape: "hexagon"
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "22AD24EC0678727A"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eКак узнать, какое снаряжение мне нужно?"
			x: 0.0d
			y: 0.5d
		}
		{
			dependencies: ["6930C77988A640AF"]
			description: [
				"&7Статистика, также известная как атрибуты, — это серия чисел, связанных с твоим персонажем, в зависимости от которых могут масштабироваться твои навыки."
				""
				"&7Например, спешка определяет, как быстро ты атакуешь, в то время как здоровье определяет, сколько очков здоровья у тебя есть, и так далее."
				""
				"&7Следующие квесты объяснят основные характеристики и как каждая из них важна для определённого использования."
				""
				"&eСтатистика — это основная часть твоего снаряжения, поэтому важно понять, какие характеристики тебе нужны, а какие — нет, в зависимости от того, как ты хочешь строить своего персонажа."
			]
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "fwaystones:item/empty_waystone_scroll"
				}
			}
			id: "44D9519561FE2D1B"
			shape: "hexagon"
			size: 1.0d
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "30BD1DF965773137"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eКак работают характеристики?"
			x: 0.0d
			y: -4.5d
		}
		{
			dependencies: ["44D9519561FE2D1B"]
			description: [
				"&eОсновные характеристики — это те характеристики, которые использует каждый в той или иной степени."
				""
				"&7Либо потому, что у тебя уже есть базовое количество этой характеристики (например, здоровье), либо потому, что любая деталь снаряжения даёт эту характеристику (например, Спешка и Броня)"
			]
			hide: true
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "minecraft:textures/gui/sprites/hud/heart/frozen_hardcore_full.png"
				}
			}
			id: "3F794C7D175F14C0"
			shape: "hexagon"
			size: 1.1d
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "6F23FA02C5CA4AD2"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eОсновные характеристики"
			x: -1.5d
			y: -5.5d
		}
		{
			dependencies: ["44D9519561FE2D1B"]
			description: [
				"&eРазные характеристики, предназначенные для дальнобойных опций."
				""
				"&7Хотя Физический урон используется всеми, дальнобойные сборки будут предпочитать другие характеристики в зависимости от выбранного пути: &eСтрельба из лука&7 (Дальний Физический урон) или &eЗаклинание&7 (Дальняя Магия)"
				""
				"&7Магия также может использоваться в ближнем бою с билдом Магического Мечника."
			]
			hide: true
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "ranged_weapon:textures/mob_effect/damage.png"
				}
			}
			id: "479F0EDD5681A06D"
			shape: "hexagon"
			size: 1.1d
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "5C9AFBF0E99AE7AC"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eХарактеристики Дальнего боя \\& Магии"
			x: 1.5d
			y: -5.5d
		}
		{
			dependencies: ["3F794C7D175F14C0"]
			description: [
				"&eСпешка увеличивает твою скорость физической атаки."
				""
				"&7Заставляет тебя атаковать или менять оружие быстрее. Также масштабируется с определённым оружием и предметами. Особое внимание для билдов «Разбойника» или любых сборок с быстрыми атаками."
			]
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "prominent:textures/icon/talent_tree/attack_speed.png"
				}
			}
			id: "3EFD57AABC3D44EF"
			shape: "circle"
			size: 0.75d
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "696BC3B958325A55"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&eСпешка"
			x: -1.5d
			y: -4.5d
		}
		{
			dependencies: ["3F794C7D175F14C0"]
			description: [
				"&eУвеличивает количество урона, который наносят твои удары/пощечины."
				""
				"&7Основная характеристика для билдов ближнего боя, так как она увеличивает наносимый тобою урон и масштабируется с любым оружием или способностями, наносящими физический урон, такими как оружие и способности ближнего боя."
			]
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "prominent:textures/icon/talent_tree/attack.png"
				}
			}
			id: "401B24F826A490C3"
			shape: "circle"
			size: 0.754d
			subtitle: "&8[Нажми, чтобы узнать больше]"
			tasks: [{
				id: "019217B93D9FE657"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&6Физический урон"
			x: -1.5d
			y: -6.5d
		}
		{
			dependencies: ["3F794C7D175F14C0"]
			description: [
				"- &eБроня"
				"&7Уменьшает входящий &6Физический урон&7."
				""
				"&7Получается от частей брони, но у врагов и боссов также будет определённое количество брони по умолчанию."
				""
				"- &eТвёрдость брони"
				"&7Уменьшает входящий &6Физический урон&7 в большем диапазоне. Это более эффективно при высоком уроне, поэтому эта характеристика известна как «Анти-Один Удар»."
			]
			icon: {
				Count: 1b
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "prominent:textures/icon/talent_tree/defense.png"
				}
			}
