			}]
			title: "&f &cРукавица, Первый Вестник Преисподней"
			x: -12.234693877551024d
			y: 0.3214285714285765d
		}
		{
			dependencies: ["7CBAFED315D614C3"]
			dependency_requirement: "one_completed"
			description: [
				"&eРекомендуемый Уровень: 10"
				"&cБольше подходит для дальнего боя"
				""
				"&7&oДавно разложившиеся души всех королей королевства Ли'релл были Пустотой воскрешены и искажены, теперь известные как единый монстр, названный Ночным Личом."
				""
				"&7&oНочной Лич дремлет на поверхности Верхнего мира. Разыскай его в биомах холодных, в остатках разрушенной башни."
				""
				"&7&oДабы найти эту структуру, используй Звезды Душ, носимые нежитью, которые должны к башне тебя направить."
				""
				"&eПодсказка: &7Это босс дальнего боя, используй летающего маунта если ты воин ближнего боя, или лук в качестве второстепенного оружия!"
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
