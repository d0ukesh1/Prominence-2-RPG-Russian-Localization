	quests: [
		{
			dependencies: [
				"49C9DC2F3D131A14"
				"5B31D4D4029F1891"
			]
			dependency_requirement: "one_completed"
			description: [
				"&eРекомендованный уровень: 15"
				""
				"&7&oРукавица, прежде зоркий смотритель и первый вестник Преисподней, теперь же падшая в темные объятья Пустоты. Порабощенная под знаменем одной из вестников Пустоты, ныне угрожающая разрушением своей собственной реальности."
				""
				"&7&oТы же можешь Рукавицу отыскать, в монолитной тюрьме запертую. Разбей её око, и пробуди теперь уже испорченное создание."
				""
				"&eПодсказка: &7Этот босс имеет сильные удары и может убить тебя с одного удара, если ты играешь на Нормальной или Сложной сложности! Пытайся уклоняться или создай защитные зелья!"
			]
			id: "1B76F8D3B54F3FE6"
			min_required_dependencies: 1
			rewards: [
				{
					id: "466ECA697E5C8AD1"
