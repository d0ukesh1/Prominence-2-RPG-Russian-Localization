		}
		{
			dependencies: ["343EF47C470616FF"]
			dependency_requirement: "one_completed"
			description: [
				"&o&7Но сейчас, когда вечность прошла, С'келлак слаб как прежде никогда. Ужасающая тень расцветает, сверхъестественная сила, Пустотой именуемая."
				""
				"&o&7Веками, Пустоту сдерживал С'келлак, но когда мощь его теперь в истощении, тень вспыхивает, замышляя разрыв и уничтожение всех реальностей. Что однажды было безмятежными созданиями, будут теперь искривлены в смертоносных испорченных тварей, пока искажение раскидывает свои мерзкие щупальца. Час расплаты близится."
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			icon: "bosses_of_mass_destruction:void_thorn"
			id: "7AE1542456418BCD"
			shape: "pentagon"
			size: 1.5d
			subtitle: "&8[Нажми, чтобы прочитать лор]"
			tasks: [{
				id: "64C1384346BEE406"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "Теневой Всплеск"
			x: -12.234693877551024d
			y: -5.464285714285708d
		}
		{
			dependencies: ["214E47AB3004E7D3"]
			dependency_requirement: "one_completed"
			description: [
				"&o&7С'келлак, нынешне обнаружил источник, равновесие нарушивший, в пределах реальностей. Все измерения ощутили прикосновения ужасающей Пустоты."
				""
				"&o&7Тихие когда-то существа были искривлены в мощных испорченных созданий её искажающим влиянием. Реальностей судьба лежит на тебе."
			]
			hide_until_deps_complete: true
			hide_until_deps_visible: true
			icon: "ftbquests:book"
			id: "7CBAFED315D614C3"
			shape: "diamond"
			size: 1.5d
			subtitle: "&8[Нажми чтобы прочитать больше]"
			tasks: [{
				id: "444189B4E513644B"
				title: "Продолжить"
				type: "checkmark"
			}]
			title: "&6&lГлава I: &eВторжение Пустоты"
			x: -12.234693877551024d
			y: -3.464285714285708d
		}
		{
			dependencies: ["0E567E587E669BED"]
			dependency_requirement: "one_completed"
			description: [
				"&7&oС победой угроз межпространственных, и восстановлением реальностей баланса, С'келлак, Вечный Пламень, заговорил напрямую с чемпионом."
				""
				"&6\"В признание доблести твоей и твоего упорства,\"&r &7&oсрезонировал голос С'келлака,&r &6\"Дарую я тебе частицу моей эссенции, Литое Ядро.\""
				""
				"&7Этот дар, освященный силой С'келлака, знаменует как триумф героя, так и его клятву продолжать защиту реальностей."
			]
			hide_until_deps_complete: true
